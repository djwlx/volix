{
  "compilerOptions": {
    "target": "esnext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@volix/types": ["../../packages/types/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "outDir": "dist",
    "noEmit": false,
    "noImplicitAny": true
  },
  "include": ["app.ts", "src/**/*", "scripts/*", "config/*"]
}
