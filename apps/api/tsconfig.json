{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noImplicitAny": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@volix/types": ["../../pacakges/types/src/index.ts"]
    }
  },
  "include": ["app.ts", "src/**/*", "public/*", "scripts/**/*"],
  "exclude": ["node_modules"]
}
